generator client {

 provider = "prisma-client-js"

}

datasource db {

 provider = "sqlite"

 url = "file:./dev.db"

}

model Product {

 id String @id @default(cuid())

 title String

 slug String @unique

 description String

 image String

 price Int

 fileUrl String

 createdAt DateTime @default(now())

}
